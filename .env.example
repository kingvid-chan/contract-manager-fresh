# Contract Manager Configuration
# Copy to .env and adjust as needed

# Application
APP_NAME=Contract Manager
APP_VERSION=0.0.1
BASE_PATH=/projects/contract-manager-fresh
VERSION_TOKEN=0.0.1

# Database
DATABASE_URL=sqlite:///./data/contract_manager.db

# Session
SECRET_KEY=change-me-to-a-random-string-in-production
SESSION_MAX_AGE=86400

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Demo accounts
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123
DEMO_USER_USERNAME=user
DEMO_USER_PASSWORD=user123
